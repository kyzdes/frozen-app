{
  "uid": "freezer-analytics",
  "title": "Freezer Analytics",
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Event rate (5m)",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (event) (rate(freezer_analytics_events_total[5m]))",
          "legendFormat": "{{event}}"
        }
      ],
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 0 },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 10 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Events last 24h",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (event) (increase(freezer_analytics_events_total[24h]))",
          "legendFormat": "{{event}}"
        }
      ],
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 9 },
      "options": {
        "colorMode": "palette-classic",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1000 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "logs",
      "title": "Recent analytics events (Loki)",
      "datasource": {
        "type": "loki",
        "uid": "Loki"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{container=\"freezer-api\"} |= \"analytics_event\"",
          "queryType": "range"
        }
      ],
      "gridPos": { "h": 11, "w": 24, "x": 0, "y": 15 },
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "showCommonLabels": true,
        "showLabels": true,
        "showTime": true,
        "wrapLogMessage": true
      }
    }
  ]
}
