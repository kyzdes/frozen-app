# Database
DATABASE_URL=postgresql://freezer:your_password@localhost:5432/freezer

# JWT
JWT_SECRET=your_very_long_random_secret_here_at_least_32_characters

# Server
PORT=3000
NODE_ENV=development
HOST=0.0.0.0
TRUST_PROXY=false

# CORS (comma-separated origins in production)
CORS_ORIGIN=true

# Metrics endpoint hardening
METRICS_ENABLED=true
# METRICS_TOKEN=change_me

# Logging
LOG_LEVEL=info
